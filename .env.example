# .env.example — Vehicle Soft / Transport Report
# Copy this file to .env for local development, or set these as system
# environment variables on the Windows Server (see docs/DEPLOYMENT_SECURITY.md).
#
# DO NOT put real secrets in this file.
# DO NOT commit a .env file with real values to version control.

# Required. Flask session signing key.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-strong-random-value

# Required for Topaz fuel agent sync.
# Must match the token configured in the Topaz agent software.
FUEL_API_TOKEN=change-me-to-your-topaz-agent-token

# Optional. Selects the config profile: dev | sqlite_prod | prod
# Default on the server is sqlite_prod (set by run_server.py).
FLASK_ENV=sqlite_prod

# Optional. Overrides the server bind address and port.
HOST=0.0.0.0
PORT=5050
